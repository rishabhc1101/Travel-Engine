# ── TravelEngine deployment config template ───────────────────────
# Copy this file to .env.deploy and fill in your values.
# .env.deploy is gitignored — never commit it.

GCP_PROJECT_ID="your-gcp-project-id"
GCP_REGION="us-central1"
DB_PASSWORD="choose-a-strong-password"
OPENWEATHERMAP_API_KEY=""   # https://openweathermap.org/api
FIREBASE_PROJECT_ID="your-firebase-project-id"
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""
VITE_GOOGLE_MAPS_API_KEY=""  # https://console.cloud.google.com/apis/credentials
